# ─────────────────────────────────────────────────────────────────────────────
# SmartRecruit AI — Backend environment variables
#
# LOCAL DEVELOPMENT
#   Copy this file to .env and fill in the values.
#   .env is gitignored — never commit real secrets.
#
# PRODUCTION (Render.com)
#   Set these in Render dashboard → your service → Environment → Add env var.
#   render.yaml already handles SENTENCE_TRANSFORMERS_HOME + PYTHON_VERSION.
#   The four variables marked [REQUIRED] must be set manually.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME="SmartRecruit AI"
ENVIRONMENT=development       # change to "production" on Render
DEBUG=false

# ── Database  [REQUIRED in production] ───────────────────────────────────────
# Local: PostgreSQL running on your machine
DATABASE_URL=postgresql://smartrecruit:smartrecruit_pass@localhost:5432/smartrecruit_db
POSTGRES_USER=smartrecruit
POSTGRES_PASSWORD=smartrecruit_pass
POSTGRES_DB=smartrecruit_db

# Neon.tech (production):
#   Copy from Neon dashboard → your project → Connection Details → Connection string
#   It already includes ?sslmode=require — paste as-is.
# DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# ── JWT  [REQUIRED in production] ────────────────────────────────────────────
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
# On Render: use generateValue: true in render.yaml (auto-generated).
SECRET_KEY=changethisinproduction_replacewithsecurekey
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── CORS  [REQUIRED in production] ───────────────────────────────────────────
# Local: wildcard is fine (default in config.py)
# ALLOWED_ORIGINS=*

# Production — your Vercel URL (no trailing slash, no quotes):
# ALLOWED_ORIGINS=https://smartrecruit-ai.vercel.app
#
# Multiple preview URLs (comma-separated):
# ALLOWED_ORIGINS=https://smartrecruit-ai.vercel.app,https://smartrecruit-ai-git-main-youruser.vercel.app

# ── Groq LLM  [OPTIONAL — enables AI-powered CV + job extraction] ─────────────
# Get your free key at https://console.groq.com/keys
# If unset, the system falls back to regex-based extraction automatically.
GROQ_API_KEY=

# ── File uploads ──────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10

# ── AI model cache  [set automatically by render.yaml] ───────────────────────
# Tells sentence-transformers where to cache the model downloaded during build.
# Leave unset locally (defaults to ~/.cache/huggingface/).
# SENTENCE_TRANSFORMERS_HOME=./st_model_cache
