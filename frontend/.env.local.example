# ─────────────────────────────────────────────────────────────────────────────
# SmartRecruit AI — Frontend environment variables
#
# LOCAL DEVELOPMENT
#   Copy this file to .env.local — it is gitignored.
#   Point to whichever port your local backend is running on.
#
# PRODUCTION (Vercel)
#   Set this in Vercel dashboard → your project → Settings → Environment Variables.
#   Use the "Production" scope so it only applies to main branch deploys.
# ─────────────────────────────────────────────────────────────────────────────

# Base URL of the FastAPI backend — no trailing slash.
#
# Local development (default):
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# If your local backend runs on 8001 (e.g. after a port conflict):
# NEXT_PUBLIC_API_URL=http://localhost:8001/api/v1

# Production — replace with your actual Render service URL:
# NEXT_PUBLIC_API_URL=https://smartrecruit-api.onrender.com/api/v1
